---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getDocs } from '@/data/docs';

const docs = getDocs('ru');
---
<BaseLayout title="Документы">
  <section class="bg-brand-blue text-white py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4">Документы</h1>
      <p class="text-blue-200 text-lg">Официальные документы и рабочие материалы CT-ARI</p>
    </div>
  </section>
  <section class="py-16 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="space-y-3">
      {docs.map(({ title, href, date }) => (
        <a href={href}
          class="flex items-center justify-between bg-brand-gray hover:bg-gray-100 rounded-xl px-6 py-4 border border-gray-100 transition-colors group">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-lg bg-brand-blue/10 flex items-center justify-center text-brand-blue group-hover:bg-brand-blue group-hover:text-white transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-gray-900 group-hover:text-brand-blue transition-colors">{title}</div>
              <div class="text-xs text-gray-400">{date}</div>
            </div>
          </div>
          <svg class="w-5 h-5 text-gray-400 group-hover:text-brand-blue transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
          </svg>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
