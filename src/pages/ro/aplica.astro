---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Aplică" description="Aplică pentru a deveni membru al Consiliului de Tineret CT-ARI">
  <section class="bg-brand-blue text-white py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4">Alătură-te CT-ARI</h1>
      <p class="text-blue-200 text-lg">Selecția membrilor — Mai 2026</p>
    </div>
  </section>

  <section class="py-16 max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Eligibility -->
    <h2 class="text-2xl font-bold text-brand-blue mb-6">Criterii de eligibilitate</h2>
    <ul class="space-y-3 mb-12">
      {[
        'Apartenența la un grup etnic sau interes demonstrat pentru diversitatea etnică',
        'Motivația și disponibilitatea de implicare civică',
        'Capacitatea de a reprezenta și promova interesele tinerilor din comunitate',
        'Vârsta: 16–30 ani',
      ].map(item => (
        <li class="flex items-start gap-3 text-gray-700">
          <span class="text-brand-amber font-bold mt-0.5">✓</span>
          <span>{item}</span>
        </li>
      ))}
    </ul>

    <!-- Process -->
    <h2 class="text-2xl font-bold text-brand-blue mb-6">Procesul de selecție</h2>
    <div class="space-y-4 mb-12">
      {[
        { step: '01', title: 'Depune dosarul', desc: 'Completează formularul online de aplicare.' },
        { step: '02', title: 'Interviu individual', desc: 'Candidații selectați vor fi invitați la un interviu cu Comisia de selecție.' },
        { step: '03', title: 'Validare oficială', desc: 'Membrii confirmați vor fi validați oficial în Iunie 2026.' },
      ].map(({ step, title, desc }) => (
        <div class="flex gap-5 items-start bg-brand-gray rounded-xl p-5">
          <div class="text-3xl font-extrabold text-brand-amber/30 leading-none">{step}</div>
          <div>
            <div class="font-bold text-brand-blue">{title}</div>
            <div class="text-sm text-gray-600">{desc}</div>
          </div>
        </div>
      ))}
    </div>

    <!-- Google Form embed placeholder -->
    <div class="bg-brand-amber/10 border-2 border-brand-amber rounded-2xl p-8 text-center">
      <h3 class="text-xl font-bold text-brand-blue mb-2">Formular de aplicare</h3>
      <p class="text-gray-600 text-sm mb-6">Completează formularul pentru a-ți depune candidatura. Dosarele se acceptă în Mai 2026.</p>
      <!-- Replace the href below with your actual Google Form URL -->
      <a
        href="https://forms.gle/qBzpkRu39W9Hw8yk7"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center px-8 py-4 bg-brand-blue text-white font-bold rounded-xl hover:bg-brand-blueLight transition-colors shadow-lg"
      >
        Completează dosarul →
      </a>
    </div>

  </section>
</BaseLayout>
