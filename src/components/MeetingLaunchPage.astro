---
import { getMeetingLaunchContent, meetingLaunchConfig, type MeetingLaunchLang } from '@/data/meetingLaunch';

interface Props {
  lang: MeetingLaunchLang;
}

const { lang } = Astro.props;
const content = getMeetingLaunchContent(lang);
const governanceUrl = meetingLaunchConfig.governanceUrl;
const applyUrl = `${meetingLaunchConfig.governanceUrl.replace(/\/$/, '')}/apply`;
const embedId = `dopomoha-governance-embed-${lang}`;
const locale = lang === 'ru' ? 'ru-RU' : 'ro-MD';
---

<section class="bg-gradient-to-br from-brand-blue via-brand-blueLight to-sky-700 text-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
    <div
      class="max-w-4xl space-y-6"
      data-meeting-launch
      data-feed-url={meetingLaunchConfig.governanceFeedUrl}
      data-governance-url={governanceUrl}
      data-locale={locale}
      data-observe-label={content.observeLabel}
      data-details-label={content.detailsLabel}
      data-apply-label={content.applyLabel}
      data-apply-url={applyUrl}
      data-full-page-label={content.fullPageLabel}
      data-pending-label={content.observePendingLabel}
      data-pending-body={content.observePendingBody}
    >
      <span class="inline-flex items-center rounded-full bg-brand-amber px-4 py-1 text-xs font-bold uppercase tracking-[0.28em] text-brand-blue">
        {content.banner}
      </span>
      <div class="space-y-4">
        <h1 class="text-4xl font-extrabold leading-tight md:text-5xl">{content.meetingPageTitle}</h1>
        <p class="max-w-3xl text-lg leading-8 text-blue-50/90">{content.meetingPageIntro}</p>
      </div>
      <div class="inline-flex max-w-3xl rounded-2xl border border-white/15 bg-white/10 px-5 py-4 text-sm leading-6 text-blue-50/90" data-launch-schedule>
        {content.scheduleLabel}
      </div>
      <div class="flex flex-col gap-3 sm:flex-row" data-launch-top-actions>
        <div class="rounded-2xl border border-brand-amber/30 bg-brand-amber/15 px-5 py-4 text-sm font-medium text-brand-amber" data-launch-observe-state>
          {content.observePendingLabel}
        </div>
        <a
          href={applyUrl}
          target="_blank"
          rel="noreferrer noopener"
          data-launch-apply-link
          class="inline-flex items-center justify-center rounded-2xl border border-white/25 bg-white/10 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-white/20"
        >
          {content.applyLabel}
        </a>
        <a
          href={governanceUrl}
          target="_blank"
          rel="noreferrer noopener"
          data-launch-full-page
          class="inline-flex items-center justify-center rounded-2xl border border-white/25 bg-white/10 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-white/20"
        >
          {content.fullPageLabel}
        </a>
      </div>
    </div>
  </div>
</section>

<section class="bg-brand-gray py-14">
  <div class="max-w-6xl mx-auto grid gap-8 px-4 sm:px-6 lg:px-8 lg:grid-cols-[1.25fr_0.75fr]">
    <article class="rounded-[2rem] border border-brand-blue/10 bg-white p-6 shadow-sm md:p-8">
      <div class="space-y-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-brand-amber">{content.embedTitle}</p>
          <h2 class="mt-2 text-2xl font-bold text-brand-blue md:text-3xl">{content.governanceLabel}</h2>
        </div>
        <p class="text-base leading-7 text-gray-600">{content.embedBody}</p>
        <div class="rounded-2xl border border-brand-amber/20 bg-amber-50 px-5 py-4 text-sm leading-6 text-amber-900" data-launch-pending-body>
          {content.observePendingBody}
        </div>
      </div>

      <div class="mt-8 rounded-[1.75rem] border border-brand-blue/10 bg-slate-50 p-5 md:p-6">
        <div class="space-y-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-brand-amber">{content.meetingListTitle}</p>
            <p class="mt-2 text-sm leading-6 text-gray-600">{content.meetingPageNotice}</p>
          </div>
          <div id={embedId} class="space-y-4">
            <div class="flex min-h-[220px] items-center justify-center rounded-2xl border border-dashed border-brand-blue/15 bg-white px-6 py-10 text-center text-sm leading-6 text-gray-500">
              {content.meetingListLoading}
            </div>
          </div>
        </div>
      </div>

      <div class="mt-6 flex flex-col gap-3 sm:flex-row">
        <a
          href={governanceUrl}
          target="_blank"
          rel="noreferrer noopener"
          class="inline-flex items-center justify-center rounded-2xl bg-brand-blue px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-brand-blueLight"
        >
          {content.fullPageLabel}
        </a>
        <div class="hidden" data-launch-bottom-observe></div>
      </div>
    </article>

    <aside class="space-y-6">
      <article class="rounded-[2rem] border border-brand-blue/10 bg-white p-6 shadow-sm">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-brand-amber">{content.inviteOnlyTitle}</p>
        <p class="mt-3 text-base leading-7 text-gray-600">{content.inviteOnlyBody}</p>
      </article>

      <article class="rounded-[2rem] border border-brand-blue/10 bg-brand-blue px-6 py-7 text-white shadow-sm">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-brand-amber">Governance public</p>
        <p class="mt-3 text-base leading-7 text-blue-50/90">{content.meetingPageNotice}</p>
      </article>
    </aside>
  </div>
</section>

<script is:inline define:vars={{ locale, embedId }}>
  (() => {
    const root = document.querySelector('[data-meeting-launch]');
    if (!root) return;

    const feedUrl = root.getAttribute('data-feed-url');
    const governanceUrl = root.getAttribute('data-governance-url') || '/';
    const observeLabel = root.getAttribute('data-observe-label') || 'Observe online';
    const fullPageLabel = root.getAttribute('data-full-page-label') || 'Open governance';
    const applyLabel = root.getAttribute('data-apply-label') || 'Apply / participate';
    const detailsLabel = root.getAttribute('data-details-label') || 'Open meeting details';
    const applyUrl = root.getAttribute('data-apply-url') || '/';
    const pendingLabel = root.getAttribute('data-pending-label') || 'Link pending';
    const pendingBody = root.getAttribute('data-pending-body') || '';
    const observeState = root.querySelector('[data-launch-observe-state]');
    const topActions = root.querySelector('[data-launch-top-actions]');
    const applyLink = root.querySelector('[data-launch-apply-link]');
    const fullPageLink = root.querySelector('[data-launch-full-page]');
    const schedule = root.querySelector('[data-launch-schedule]');
    const bottomObserve = document.querySelector('[data-launch-bottom-observe]');
    const pendingBodyCard = document.querySelector('[data-launch-pending-body]');
    const eventsRoot = document.getElementById(embedId);

    const buildObserveLink = (href, primary) => {
      const link = document.createElement('a');
      link.href = href;
      link.target = '_blank';
      link.rel = 'noreferrer noopener';
      link.textContent = observeLabel;
      link.className = primary
        ? 'inline-flex items-center justify-center rounded-2xl bg-brand-amber px-6 py-3 text-sm font-bold text-brand-blue transition-colors hover:bg-brand-amberLight'
        : 'inline-flex items-center justify-center rounded-2xl border border-brand-blue/15 bg-white px-6 py-3 text-sm font-semibold text-brand-blue transition-colors hover:border-brand-blue hover:bg-brand-gray';
      return link;
    };

    const parseFeedDate = (value) => {
      if (!value) {
        return null;
      }

      const normalized = /(?:Z|[+-]\d{2}:\d{2})$/i.test(value)
        ? value
        : `${value}Z`;
      const parsed = new Date(normalized);
      return Number.isNaN(parsed.getTime()) ? null : parsed;
    };

    const formatSchedule = (event) => {
      if (!event?.scheduledStartUtc) {
        return null;
      }

      const start = parseFeedDate(event.scheduledStartUtc);
      if (!start) {
        return null;
      }

      const base = new Intl.DateTimeFormat(locale, {
        dateStyle: 'long',
        timeStyle: 'short',
        timeZone: 'Europe/Chisinau',
      }).format(start);

      if (event.location) {
        return `${base} · ${event.location}`;
      }

      if (event.remoteJoinUrl) {
        return `${base} · Online`;
      }

      return base;
    };

    const setPendingState = () => {
      if (observeState) {
        observeState.textContent = pendingLabel;
      }
      if (bottomObserve) {
        bottomObserve.classList.add('hidden');
        bottomObserve.replaceChildren();
      }
      if (pendingBodyCard) {
        pendingBodyCard.classList.remove('hidden');
      }
      if (eventsRoot) {
        eventsRoot.replaceChildren(buildEmptyState(pendingBody || pendingLabel));
      }
    };

    const buildEmptyState = (message) => {
      const wrapper = document.createElement('div');
      wrapper.className = 'flex min-h-[220px] items-center justify-center rounded-2xl border border-dashed border-brand-blue/15 bg-white px-6 py-10 text-center text-sm leading-6 text-gray-500';
      wrapper.textContent = message || pendingLabel;
      return wrapper;
    };

    const buildEventCard = (event) => {
      const card = document.createElement('article');
      card.className = 'rounded-2xl border border-white/90 bg-white p-5 shadow-sm ring-1 ring-brand-blue/10';

      const badge = document.createElement('span');
      badge.className = 'inline-flex items-center rounded-full bg-brand-amber/15 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-brand-blue';
      badge.textContent = event.sourceKind === 'governance-meeting' ? 'Ședință' : 'Sesiune';
      card.appendChild(badge);

      const title = document.createElement(event.detailsUrl ? 'a' : 'h3');
      title.className = 'mt-3 text-lg font-bold text-brand-blue';
      title.textContent = event.title || '';
      if (title instanceof HTMLAnchorElement) {
        title.href = event.detailsUrl;
        title.target = '_blank';
        title.rel = 'noreferrer noopener';
        title.className += ' no-underline hover:underline';
      }
      card.appendChild(title);

      const meta = document.createElement('div');
      meta.className = 'mt-2 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-gray-500';
      const scheduled = parseFeedDate(event.scheduledStartUtc);
      if (scheduled) {
        meta.appendChild(document.createTextNode(new Intl.DateTimeFormat(locale, {
          dateStyle: 'long',
          timeStyle: 'short',
          timeZone: 'Europe/Chisinau',
        }).format(scheduled)));
      }
      if (event.location) {
        const location = document.createElement('span');
        location.textContent = event.location;
        meta.appendChild(location);
      } else if (event.remoteJoinUrl) {
        const online = document.createElement('span');
        online.textContent = 'Online';
        meta.appendChild(online);
      }
      card.appendChild(meta);

      if (event.scopeDisplayLabel) {
        const scope = document.createElement('p');
        scope.className = 'mt-3 text-sm leading-6 text-gray-600';
        scope.textContent = event.scopeDisplayLabel;
        card.appendChild(scope);
      }

      const actions = document.createElement('div');
      actions.className = 'mt-4 flex flex-col gap-3 sm:flex-row';

      if (event.remoteJoinUrl) {
        const observeLink = buildObserveLink(event.remoteJoinUrl, true);
        actions.appendChild(observeLink);
      }

      const full = document.createElement('a');
      full.href = event.detailsUrl || governanceUrl;
      full.target = '_blank';
      full.rel = 'noreferrer noopener';
      full.className = 'inline-flex items-center justify-center rounded-2xl border border-brand-blue/15 bg-white px-5 py-3 text-sm font-semibold text-brand-blue transition-colors hover:border-brand-blue hover:bg-brand-gray';
      full.textContent = event.detailsUrl ? detailsLabel : fullPageLabel;
      actions.appendChild(full);

      card.appendChild(actions);
      return card;
    };

    const hydrate = async () => {
      if (!feedUrl) return;
      try {
        const response = await fetch(feedUrl, { mode: 'cors' });
        if (!response.ok) {
          setPendingState();
          return;
        }

        const feed = await response.json();
        const nextEvent = Array.isArray(feed?.upcomingEvents) ? feed.upcomingEvents[0] : null;
        const events = Array.isArray(feed?.upcomingEvents) ? feed.upcomingEvents : [];

        if (schedule) {
          const nextSchedule = formatSchedule(nextEvent);
          if (nextSchedule) {
            schedule.textContent = nextSchedule;
          }
        }

        if (feed?.observerUrl && observeState && topActions && bottomObserve) {
          const topLink = buildObserveLink(feed.observerUrl, true);
          observeState.replaceWith(topLink);
          bottomObserve.classList.remove('hidden');
          bottomObserve.replaceChildren(buildObserveLink(feed.observerUrl, false));
          if (pendingBodyCard) {
            pendingBodyCard.classList.add('hidden');
          }
        } else {
          setPendingState();
          if (observeState && pendingBody) {
            observeState.setAttribute('title', pendingBody);
          }
        }

        if (feed?.applicationUrl && applyLink instanceof HTMLAnchorElement) {
          applyLink.href = feed.applicationUrl;
          applyLink.textContent = applyLabel;
        } else if (applyLink instanceof HTMLAnchorElement) {
          applyLink.href = applyUrl;
        }

        if (feed?.governanceUrl && fullPageLink instanceof HTMLAnchorElement) {
          fullPageLink.href = feed.governanceUrl;
          fullPageLink.textContent = fullPageLabel;
        } else if (fullPageLink instanceof HTMLAnchorElement) {
          fullPageLink.href = governanceUrl;
        }

        if (eventsRoot) {
          if (events.length === 0) {
            eventsRoot.replaceChildren(buildEmptyState(pendingBody || pendingLabel));
          } else {
            const fragment = document.createDocumentFragment();
            events.forEach((event) => fragment.appendChild(buildEventCard(event)));
            eventsRoot.replaceChildren(fragment);
          }
        }
      } catch (error) {
        console.error('Failed to hydrate meeting launch page', error);
        setPendingState();
      }
    };

    hydrate();
  })();
</script>
